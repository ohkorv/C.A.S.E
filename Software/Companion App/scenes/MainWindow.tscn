[sub_resource type="CSharpScript" id="CSharpScript_lelwj"]
script/source = "using Godot;
using System.Collections.Generic;
using System.IO;
using System.Threading.Tasks;
using System.Diagnostics;

public partial class FileTransfer : Godot.Control
{
	[Export] public Godot.NodePath DropZonePath;
	[Export] public Godot.NodePath FileListPath;
	[Export] public Godot.NodePath SendButtonPath;
	[Export] public Godot.NodePath TransferStatusLabelPath;
	[Export] public Godot.NodePath TransferProgressBarPath;

	private Godot.Panel _dropZone;
	private Godot.VBoxContainer _fileList;
	private Godot.Button _sendButton;
	private Godot.Label _transferStatusLabel;
	private Godot.ProgressBar _transferProgressBar;

	private List<(string Path, long Size)> _filesToSend = new();

	public override void _Ready()
	{
		_dropZone = GetNode<Godot.Panel>(DropZonePath);
		_fileList = GetNode<Godot.VBoxContainer>(FileListPath);
		_sendButton = GetNode<Godot.Button>(SendButtonPath);
		_transferStatusLabel = GetNode<Godot.Label>(TransferStatusLabelPath);
		_transferProgressBar = GetNode<Godot.ProgressBar>(TransferProgressBarPath);

		_sendButton.Pressed += OnSendPressed;
		_sendButton.Disabled = true;
		_transferProgressBar.Visible = false;
		_dropZone.GuiInput += OnDropZoneInput;
	}

	private void OnDropZoneInput(Godot.InputEvent @event)
	{
		if (@event is InputEventMouseButton mb && mb.Pressed && mb.ButtonIndex == MouseButton.Left)
			OpenFileDialog();
	}

	private void OpenFileDialog()
	{
		var psi = new ProcessStartInfo
		{
			FileName = \"powershell\",
			Arguments = \"-NoProfile -Command \\\"Add-Type -AssemblyName System.Windows.Forms; $f = New-Object System.Windows.Forms.OpenFileDialog; $f.Multiselect = $true; $f.Filter = 'FLAC Audio (*.flac)|*.flac|All Files (*.*)|*.*'; $f.ShowDialog() | Out-Null; $f.FileNames -join '|'\\\"\",
			RedirectStandardOutput = true,
			UseShellExecute = false,
			CreateNoWindow = true
		};

		var process = Process.Start(psi);
		string output = process.StandardOutput.ReadToEnd().Trim();
		process.WaitForExit();

		if (!string.IsNullOrEmpty(output))
		{
			foreach (var path in output.Split('|'))
			{
				if (!string.IsNullOrEmpty(path))
					AddFile(path.Trim());
			}
		}
	}

	private void AddFile(string path)
	{
		foreach (var f in _filesToSend)
			if (f.Path == path) return;

		var size = new FileInfo(path).Length;
		_filesToSend.Add((path, size));

		var row = new Godot.HBoxContainer();

		var nameLabel = new Godot.Label();
		nameLabel.Text = System.IO.Path.GetFileName(path);
		nameLabel.SizeFlagsHorizontal = Godot.Control.SizeFlags.ExpandFill;

		var sizeLabel = new Godot.Label();
		sizeLabel.Text = FormatSize(size);

		var removeBtn = new Godot.Button();
		removeBtn.Text = \"X\";
		removeBtn.Pressed += () => RemoveFile(path, row);

		row.AddChild(nameLabel);
		row.AddChild(sizeLabel);
		row.AddChild(removeBtn);
		_fileList.AddChild(row);

		_sendButton.Disabled = false;
	}

	private void RemoveFile(string path, Godot.HBoxContainer row)
	{
		_filesToSend.RemoveAll(f => f.Path == path);
		row.QueueFree();
		if (_filesToSend.Count == 0)
			_sendButton.Disabled = true;
	}

	private async void OnSendPressed()
	{
		string drive = FindEspDrive();
		if (drive == \"\")
		{
			_transferStatusLabel.Text = \"Device not found\";
			return;
		}

		_sendButton.Disabled = true;
		_transferProgressBar.Visible = true;
		_transferProgressBar.Value = 0;

		int total = _filesToSend.Count;
		int done = 0;

		foreach (var f in _filesToSend)
		{
			string filename = System.IO.Path.GetFileName(f.Path);
			_transferStatusLabel.Text = \"Sending: \" + filename;

			string destDir = drive + \"/music\";
			string dest = destDir + \"/\" + filename;

			await Task.Run(() =>
			{
				Directory.CreateDirectory(destDir);
				File.Copy(f.Path, dest, true);
			});

			done++;
			_transferProgressBar.Value = (float)done / total * 100f;
		}

		_transferStatusLabel.Text = \"Done! Sent \" + total + \" file(s)\";
		_sendButton.Disabled = false;

		await ToSignal(GetTree().CreateTimer(2.0f), \"timeout\");
		_transferProgressBar.Visible = false;
	}

	private string FindEspDrive()
	{
		foreach (var drive in DriveInfo.GetDrives())
		{
			if (drive.DriveType == DriveType.Removable && drive.IsReady)
				return drive.Name.TrimEnd('\\\\');
		}
		return \"\";
	}

	private string FormatSize(long size)
	{
		if (size < 1024) return size + \" B\";
		if (size < 1024 * 1024) return size / 1024 + \" KB\";
		return $\"{(float)size / (1024f * 1024f):0.0} MB\";
	}
}
"

