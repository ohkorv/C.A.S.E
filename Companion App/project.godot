;   param=value ; assign values to parameters

config_version=5

[application]

config/name="C.O.R.E"
run/main_scene="uid://rr24y4jtw2wa"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
boot_splash/show_image=false
config/icon="uid://cjkeblnd5imfw"

[display]

